#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "Running fast Stack-chan pre-commit checks..."
uv run ruff check .
uv run pyright
uv run pytest tests/test_mcp_server.py

if [ "${STACKCHAN_HOOK_FULL:-0}" = "1" ]; then
    echo "Running full Stack-chan handoff checks..."
    make lint
    make test
fi
