# Stack-chan host configuration.
# Copy to .env and fill local values. Do not commit .env.

# Device and host addresses.
STACKCHAN_IP="192.0.2.20"
STACKCHAN_PORT="80"
MAC_IP="192.0.2.10"
AUDIO_SERVE_PORT="5099"

# TTS / ASR.
TTS_ENGINE="fish-audio"
FISH_AUDIO_KEY="replace-with-your-fish-audio-api-key"
FISH_AUDIO_MODEL_ZH="replace-with-your-chinese-voice-model-id"
FISH_AUDIO_MODEL_EN="replace-with-your-english-voice-model-id"
EDGE_TTS_BIN="edge-tts"

# MCP Streamable HTTP mode.
STACKCHAN_PUBLIC_MCP_URL="https://stackchan.example.com/mcp"
STACKCHAN_LOG_DIR="/tmp"

# Browser / phone voice upload receiver.
STACKCHAN_VOICE_UPLOAD_HOST="127.0.0.1"
STACKCHAN_VOICE_UPLOAD_PORT="8767"
STACKCHAN_VOICE_PUBLIC_URL="https://example-tunnel.example.com"
STACKCHAN_VOICE_UPLOAD_TOKEN="replace-with-a-long-random-token"
STACKCHAN_VOICE_UPLOAD_RATE_PER_MINUTE="12"
STACKCHAN_VOICE_WAKE_WORDS="stackchan"
STACKCHAN_CLOUDFLARED_LAUNCHD_LABEL="xyz.stackchan.cloudflared"
STACKCHAN_VOICE_UPLOAD_LAUNCHD_LABEL="xyz.stackchan.voice-upload"
STACKCHAN_VOICE_BRIDGE_LABEL="xyz.stackchan.voice-bridge"

# Optional frontend wake bridge. Leave blank to keep transcripts in the local inbox only.
STACKCHAN_FRONTEND_WAKE_URL=""
STACKCHAN_FRONTEND_SESSION_ID=""
STACKCHAN_FRONTEND_SESSION_TITLE=""
STACKCHAN_FRONTEND_REGISTRY=""
STACKCHAN_FRONTEND_ENV=""
STACKCHAN_FRONTEND_TOKEN=""
STACKCHAN_FRONTEND_MODEL=""
STACKCHAN_FRONTEND_RETRIES="5"
STACKCHAN_FRONTEND_RETRY_DELAY="3"
